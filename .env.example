# Environment Configuration for HK-US Quantitative Trading Platform

# Environment
ENVIRONMENT=development

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/quant_platform
DATABASE_MAX_CONNECTIONS=20
DATABASE_MIN_CONNECTIONS=5
DATABASE_CONNECTION_TIMEOUT=30
DATABASE_IDLE_TIMEOUT=600

# Redis Configuration
REDIS_URL=redis://localhost:6379
REDIS_MAX_CONNECTIONS=10
REDIS_CONNECTION_TIMEOUT=5

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
SERVER_WORKERS=4

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=json
RUST_LOG=hk_us_quant_platform=debug,sqlx=warn,redis=warn

# Trading Configuration
DEFAULT_PORTFOLIO_ID=default
MAX_ORDER_SIZE=10000
RISK_CHECK_ENABLED=true
PAPER_TRADING=true

# Market Data Configuration
MARKET_DATA_PROVIDER=mock
MARKET_DATA_SYMBOLS=AAPL,GOOGL,MSFT,TSLA,0700.HK,0941.HK

# Risk Management Configuration
MAX_LEVERAGE=3.0
MAX_DAILY_LOSS=50000.00
MAX_POSITION_SIZE=100000
MAX_SINGLE_STOCK_WEIGHT=0.10

# Broker Configuration (for future use)
BROKER_API_URL=
BROKER_API_KEY=
BROKER_API_SECRET=
BROKER_PAPER_TRADING=true

# Monitoring Configuration
METRICS_ENABLED=true
HEALTH_CHECK_INTERVAL=30
ALERT_EMAIL=admin@example.com